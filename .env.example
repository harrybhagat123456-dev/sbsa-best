# ─── Core ──────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
GROUP_ID=YOUR_GROUP_ID_HERE          # Supergroup ID (e.g. -1001234567890)

# ─── Upload ────────────────────────────────────────────────────────────────
INPUT_FILE=./input.txt
MESSAGE_DELAY=1500                   # ms between messages
BATCH_SIZE=20                        # messages per batch
BATCH_PAUSE=5000                     # ms pause between batches
RESUME_FROM_LINE=0                   # set to resume from a specific line

# ─── Mini App ──────────────────────────────────────────────────────────────
WEBAPP_URL=https://your-project.replit.app   # Your Replit app public URL
PORT=3000
